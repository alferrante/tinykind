NEXT_PUBLIC_BASE_URL=https://tinykind.yourdomain.com
# Use an absolute writable path in production (for example /var/data on Render with a mounted disk).
TINYKIND_DATA_DIR=./data
# Optional backup settings (defaults shown).
TINYKIND_BACKUP_DIR=./data/backups
TINYKIND_BACKUP_ON_WRITE=1
TINYKIND_BACKUP_RETENTION_DAYS=30
TINYKIND_BACKUP_MAX_FILES=400
# Optional: protects admin/debug message APIs (/api/messages*). If unset, those endpoints return 404.
TINYKIND_ADMIN_TOKEN=change-me
# Optional but recommended: enables browser admin login at /admin.
ADMIN_PASSWORD=change-this-password
# Optional but recommended: enables sender magic-link auth.
TINYKIND_AUTH_SECRET=change-this-random-secret
# Optional: enables Google OAuth sign-in when both values are set.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override. Defaults to <NEXT_PUBLIC_BASE_URL>/api/auth/google/callback.
GOOGLE_REDIRECT_URI=
# Required for reminder cron endpoint authorization.
TINYKIND_CRON_TOKEN=change-this-cron-token
# Optional: set to 1 to notify sender when recipient opens a TinyKind.
OPEN_NOTIFY_ENABLED=0
# Optional: enables sender email notifications when recipients react.
RESEND_API_KEY=
TINYKIND_REACTION_FROM_EMAIL="TinyKind <reactions@tinykind.app>"
